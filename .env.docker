# Ajustes Generales de Django
SECRET_KEY=django-insecure-uagrm-icpc-platform-prod-key-2026
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Configuración de Base de Datos PostgreSQL
DB_NAME=icpc_uagrm
DB_USER=postgres
DB_PASSWORD=diego

# Configuración de CORS
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# API de OpenAI (ChatGPT 5.4) para el Juez y el Asistente Virtual
OPENAI_API_KEY=tu_clave_api_de_openai_aqui

